define(['jquery','mage/utils/wrapper','Magento_Customer/js/customer-data','Magento_Catalog/js/price-utils'],function($,wrapper,customerData,priceUtils){'use strict';var mixin={getFormattedPrice:function(price){var priceFormat={decimalSymbol:',',groupLength:3,groupSymbol:".",integerRequired:false,pattern:"$%s",precision:0,requiredPrecision:0};return priceUtils.formatPrice(price,priceFormat);},setGoalLeft:function(){this._super();var cart=customerData.get('cart');var goalLeft=this.goal-cart().baseSubtotalWithDiscount;this.goalLeft(goalLeft);if(cart().summary_count>0){$('body .amasty-shipbar').removeClass("display-none");}else{$('body .amasty-shipbar').addClass("display-none");}
cart.subscribe(function(cart){this.goalLeft(goalLeft);}.bind(this))},getRawLabelContent:function(){this._super();this.setGoalLeft();if(this.helpFlag()){return this.labels.terms_message;}
if(this.goalLeft()==this.goal){return this.labels.init_message;}
if(this.goalLeft()<=0){return this.labels.achieved_message;}
if(this.goalLeft()<this.goal){return this.labels.progress_message;}
return this.labels.init_message;},addExtraColor:function(data){return"<b style=\"color: "+this.extraColor+"\">"+this.getFormattedPrice(data)+"</b>";},};return function(OriginBar){return OriginBar.extend(mixin);};});