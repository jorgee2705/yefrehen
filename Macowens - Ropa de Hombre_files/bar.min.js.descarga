define(['Magento_Customer/js/customer-data','Magento_Catalog/js/price-utils','mage/url'],function(customerData,price,urlBuilder){'use strict';return{getData:function(subtotalWithDiscountAmount,visibilityArea){const self=this,barConfig=this._barConfig(visibilityArea);let result=[];barConfig.bar.forEach(function(item){if(self._barEnable(item,visibilityArea)){result.push({'mainMessage':self._barMainMessage(item,subtotalWithDiscountAmount,barConfig.price_format),'percentage':self._barPercentage(item,subtotalWithDiscountAmount),'brandIcon':self._barIconUrl(item),'backgroundColor':self._getBackgroundColor(item,visibilityArea),'barStartPrice':price.formatPrice(0,barConfig.price_format,false),'cartAmountGoal':price.formatPrice(item.cart_subtotal_goal,barConfig.price_format,false),'barColor':item.bar_color});}});return result;},_barConfig:function(visibilityArea){return{'bar':visibilityArea==='checkout'||visibilityArea==='cart'?window.checkoutConfig.bar:window.checkout.bar,'price_format':visibilityArea==='checkout'||visibilityArea==='cart'?window.checkoutConfig.priceFormat:window.checkout.price_format};},_barEnable:function(item,visibilityArea){let result=false;if(item.enable==="1"&&item.show_pages!==null&&item.show_pages.search(visibilityArea)!==-1){result=true;const cart=customerData.get('cart')(),virtualProducts=['virtual','downloadable','giftcard'];let cartIsVirtual=false;if(cart.items){cart.items.forEach(function(item){if(virtualProducts.includes(item.product_type)){cartIsVirtual=true;}});}
if(item.type==='shipping'&&cartIsVirtual){result=false;}}
return result;},_barPercentage:function(item,grandTotalAmount){let percent=(grandTotalAmount*100)/ item.cart_subtotal_goal;if(percent>100){percent='100';}
return percent+'%';},_barIconUrl:function(item){return item.brand_icon?urlBuilder.build('media/bar_brand_icon/'+item.brand_icon):false;},_barMainMessage:function(item,grandTotalAmount,priceFormat){let result=item.goal_message;const cartSubtotalAmountLeft=item.cart_subtotal_goal-grandTotalAmount;if(cartSubtotalAmountLeft>0){result=item.goal_left_message.replace('{{ruleGoalLeft}}',price.formatPrice(cartSubtotalAmountLeft,priceFormat,false));}
return result;},_getBackgroundColor:function(item,visibilityArea){let result=item.background_color;if(result===null||visibilityArea==='sidebar'){result='transparent';}
return result;}}});