define(['jquery','underscore'],function($,_){'use strict';return function(target){return target.extend({defaults:{isHidden:false,selector:'.page.messages .messages'},initObservable:function(){this._super().observe('isHidden');return this;},isVisible:function(){return this.isHidden(!_.isEmpty(this.messages().messages)||!_.isEmpty(this.cookieMessages));},removeAll:function(){var self=this;$(self.selector).hide();},onHiddenChange:function(isHidden){var self=this;}});};});