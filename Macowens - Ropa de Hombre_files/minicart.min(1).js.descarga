define(['uiComponent','ko','Magento_Customer/js/customer-data','Infracommerce_FeeShippingBar/js/bar'],function(Component,ko,customerData,bar){'use strict';return Component.extend({defaults:{template:'Infracommerce_FeeShippingBar/bar'},barData:ko.observable([]),initialize:function(){this._super();const self=this,cartData=customerData.get('cart');this.barData(bar.getData(cartData().subtotalAmount,this.visibilityArea));cartData.subscribe(function(data){self.barData(bar.getData(data.subtotalAmount,self.visibilityArea));});}});});