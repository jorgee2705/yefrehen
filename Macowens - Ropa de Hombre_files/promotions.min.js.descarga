define(['jquery','domReady'],function($){'use strict';var promotions={config:{},init:function(config){this.config=config;let _this=this;$('div[class*="pagebuilder"]').click(function(){if(Object.keys(this.attributes['data-background-images'].value).length>2){let promotionId=this.attributes['data-pb-style'].value;let promotionName=_this.formatPromotionName(this.attributes['data-background-images'].value);let creativeSlot=promotionName;let locationId=_this.getLocationId(this);_this.promotionsDataClick(promotionId,promotionName,creativeSlot,locationId);}
else{let promotionId=this.attributes['data-pb-style'].value;let promotionName=$('div[data-pb-style='+promotionId+'] > figure > a > img')[0].attributes['title'].value;let creativeSlot=promotionName;let locationId=_this.getLocationId(this);_this.promotionsDataClick(promotionId,promotionName,creativeSlot,locationId);}});},promotionsDataClick:function(promotionId,promotionName,creativeSlot,locationId){window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'select_promotion',ecommerce:{promotions:[{promotion_id:promotionId,promotion_name:promotionName,creative_slot:creativeSlot,location_id:locationId}]}});this.promotionsDataView(promotionId,promotionName,creativeSlot,locationId);},promotionsDataView:function(promotionId,promotionName,creativeSlot,locationId){window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'view_promotion',ecommerce:{items:[{promotion_id:promotionId,promotion_name:promotionName,creative_slot:creativeSlot,location_id:locationId}]}});},formatPromotionName:function(promotionName){let elements=promotionName.split('/');let dividers=['jpg','npg'];let partialName='';elements.forEach(elem=>{if(dividers.some(divider=>elem.includes(divider))){partialName=elem.split('.').slice(0,-1).join('');}})
return partialName.split('-').join(' ');},getLocationId:function(data){let locationId='Banner';if(data.className.includes('slide')){locationId='Banner Carrousel'}
return locationId;}}
return function(config,element){promotions.init(config);}});